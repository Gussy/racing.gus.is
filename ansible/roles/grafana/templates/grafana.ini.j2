[paths]
data = /mnt/data/grafana
provisioning = /etc/grafana/provisioning

[server]
domain = {{ domain }}
root_url = %(protocol)s://%(domain)s/grafana/
serve_from_sub_path = true

[security]
admin_user = admin
admin_password = {{ vault_grafana_admin_password }}

[users]
allow_sign_up = false

[plugins]
allow_loading_unsigned_plugins = {{ grafana_allow_unsigned_plugins }}

[log]
mode = console file
level = info
